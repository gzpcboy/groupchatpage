{
  "name": "groupchatpage",
  "version": "0.1.0",
  "description": "Serverless multi-model group chat powered by GitHub Copilot — 100% static HTML/JS",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "serve:prod": "node ./scripts/serve-dist.mjs",
    "serve:restart": "./scripts/restart-local-server.sh",
    "rollout": "./scripts/deploy.sh",
    "test": "npm run test:unit && npm run test:structure",
    "test:unit": "vitest run",
    "test:copilot:live": "vitest run tests/unit/copilot.live.test.ts",
    "test:structure": "node ./scripts/check-ts-file-length.mjs",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test e2e/*.live.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/dompurify": "^3.0.5",
    "jsdom": "^29.1.1",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "dompurify": "^3.1.6",
    "marked": "^14.1.4"
  }
}
